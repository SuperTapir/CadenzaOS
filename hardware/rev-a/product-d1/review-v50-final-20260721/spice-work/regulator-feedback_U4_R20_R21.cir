echo "vfb_sim=$&vfb_sim error_pct=$&error_pct expected=0.6009599999999999 vin=5.0 vref=0.595" > /Users/tapir/Development/CadenzaOS/hardware/rev-a/product-d1/review-v50-final-20260721/spice-work/regulator-feedback_U4_R20_R21.out
quit
.endc

