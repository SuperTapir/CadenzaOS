menu "Cadenza L2 input validation"

config L2_ENCODER_COUNTS_PER_DETENT
    int "Valid Gray-code transitions per detent"
    range 1 4
    default 4
    help
        This is deliberately configurable because the purchased EC12 has not
        yet been measured. It can also be changed with the serial `cpd` command.

config L2_ENCODER_REVERSE
    bool "Reverse reported encoder direction"
    default n
    help
        Changes only the reported direction. It does not assume which physical
        EC12 terminal is A or B. It can also be changed with `reverse`.

config L2_BUTTON_DEBOUNCE_MS
    int "Button stable time (ms)"
    range 1 100
    default 20

config L2_BUTTON_LONG_PRESS_MS
    int "Long-press threshold (ms)"
    range 100 5000
    default 800

config L2_STATUS_PERIOD_MS
    int "Periodic status interval (ms)"
    range 100 10000
    default 1000

config L2_EVENT_LOGGING
    bool "Print each encoder/button event"
    default n
    help
        Disabled by default because printing every detent can itself make a
        high-speed encoder test lose events. Runtime command `events 0|1`
        overrides this setting; periodic statistics are always printed.

endmenu
