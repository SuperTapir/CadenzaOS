{
  "version": 6,
  "configurePresets": [
    {
      "name": "host-debug",
      "displayName": "Cadenza host debug",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/host",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CADENZA_BUILD_TESTS": "ON",
        "CADENZA_BUILD_DESKTOP": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "host-debug",
      "configurePreset": "host-debug"
    },
    {
      "name": "desktop-debug",
      "configurePreset": "host-debug",
      "targets": ["cadenza_desktop"]
    }
  ],
  "testPresets": [
    {
      "name": "host-debug",
      "configurePreset": "host-debug",
      "output": {"outputOnFailure": true}
    }
  ]
}
